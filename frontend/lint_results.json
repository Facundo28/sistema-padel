w items-center gap-8\">\n                    <div className=\"w-24 h-24 rounded-full bg-brand-dark/5 flex items-center justify-center border-4 border-gray-50\">\n                        <Users size={40} className=\"text-brand-dark/20\" />\n                    </div>\n                    <div className=\"flex-1 space-y-4\">\n                        {parejaActual ? (\n                            <>\n                                <div>\n                                    <h3 className=\"text-2xl font-black text-brand-dark uppercase tracking-tighter\">\n                                        {parejaActual.apellido}, {parejaActual.nombre}\n                                    </h3>\n                                    <div className=\"flex items-center justify-center sm:justify-start gap-2 mt-1\">\n                                        <span className=\"text-brand-gray font-medium\">DNI: {parejaActual.dni}</span>\n                                        <div className=\"flex items-center gap-1 text-[10px] font-black text-green-600 bg-green-50 px-2 py-0.5 rounded border border-green-100 uppercase tracking-widest\">\n                                            <CheckCircle size={12} /> USUARIO VALIDADO\n                                        </div>\n                                    </div>\n                                </div>\n                                <button\n                                    onClick={handleDesvincular}\n                                    className=\"px-6 py-2.5 bg-red-50 text-red-500 text-[11px] font-black tracking-widest rounded-lg border border-red-100 hover:bg-red-100 transition-all uppercase flex items-center gap-2 mx-auto sm:mx-0\"\n                                >\n                                    <UserMinus size={14} /> Desvincular Pareja\n                                </button>\n                            </>\n                        ) : (\n                            <div className=\"space-y-2\">\n                                <p className=\"text-brand-gray font-medium\">No tienes ninguna pareja vinculada actualmente.</p>\n                                <p className=\"text-xs text-gray-400\">Busca a tu compañero por DNI abajo para crear el vínculo.</p>\n                            </div>\n                        )}\n                    </div>\n                </div>\n            </div>\n\n            {/* Search Section */}\n            {!parejaActual && (\n                <div className=\"bg-white rounded-xl border border-gray-100 shadow-sm overflow-hidden p-8 space-y-6\">\n                    <div>\n                        <h2 className=\"text-sm font-black text-brand-dark tracking-widest uppercase italic\">Buscar Pareja</h2>\n                        <p className=\"text-xs text-brand-gray mt-1\">Ingresa el DNI exacto de tu compañero.</p>\n                    </div>\n\n                    <form onSubmit={handleBuscar} className=\"relative group max-w-md\">\n                        <Search className=\"absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-brand-dark transition-colors\" size={20} />\n                        <div className=\"flex gap-2\">\n                            <input\n                                type=\"text\"\n                                placeholder=\"Ingresar DNI...\"\n                                value={dniBusqueda}\n                                onChange={(e) => setDniBusqueda(e.target.value)}\n                                className={inputClass}\n                            />\n                            <button\n                                type=\"submit\"\n                                disabled={buscando || !dniBusqueda}\n                                className=\"px-6 py-3 bg-brand-dark text-white rounded-lg font-black text-xs uppercase hover:bg-black transition-all disabled:opacity-50\"\n                            >\n                                {buscando ? <Loader2 size={16} className=\"animate-spin\" /> : 'BUSCAR'}\n                            </button>\n                        </div>\n                    </form>\n\n                    {usuarioEncontrado && (\n                        <div className=\"mt-6 p-6 bg-gray-50 rounded-xl border border-gray-100 animate-in slide-in-from-top-4 duration-300\">\n                            <div className=\"flex items-center justify-between gap-4\">\n                                <div className=\"flex items-center gap-4\">\n                                    <div className=\"w-12 h-12 rounded-full bg-white flex items-center justify-center border border-gray-100 shadow-sm text-brand-dark font-black\">\n                                        {usuarioEncontrado.nombre[0]}{usuarioEncontrado.apellido[0]}\n                                    </div>\n                                    <div>\n                                        <p className=\"text-sm font-black text-brand-dark uppercase tracking-tight\">\n                                            {usuarioEncontrado.apellido}, {usuarioEncontrado.nombre}\n                                        </p>\n                                        <div className=\"flex items-center gap-1.5 mt-0.5\">\n                                            <span className=\"text-xs text-brand-gray font-medium\">DNI: {usuarioEncontrado.dni}</span>\n                                            <CheckCircle size={10} className=\"text-green-500\" />\n                                            <span className=\"text-[9px] font-black text-green-600 uppercase tracking-widest\">VALIDADO</span>\n                                        </div>\n                                    </div>\n                                </div>\n                                <button\n                                    onClick={handleVincular}\n                                    className=\"flex items-center gap-2 px-6 py-3 bg-brand-dark text-white text-[11px] font-black tracking-widest rounded-lg hover:bg-black transition-all shadow-lg shadow-black/10 uppercase\"\n                                >\n                                    <UserPlus size={16} /> Vincular\n                                </button>\n                            </div>\n                        </div>\n                    )}\n                </div>\n            )}\n        </div>\n    );\n};\n\nexport default UserPareja;\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Facundo\\Documents\\Base de datos\\web_inicial\\frontend\\src\\views\\user\\UserProfile.jsx","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'setHeader'. Either include it or remove the dependency array.","line":33,"column":8,"nodeType":"ArrayExpression","endLine":33,"endColumn":19,"suggestions":[{"desc":"Update the dependencies array to be: [setHeader, user.dni]","fix":{"range":[1206,1217],"text":"[setHeader, user.dni]"}}]},{"ruleId":"no-unused-vars","severity":2,"message":"'Icon' is defined but never used.","line":64,"column":31,"nodeType":"Identifier","messageId":"unusedVar","endLine":64,"endColumn":35,"suggestions":[{"messageId":"removeVar","data":{"varName":"Icon"},"fix":{"range":[2264,2275],"text":""},"desc":"Remove unused variable 'Icon'."}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useState, useEffect } from 'react';\r\nimport { useAuth } from '../../context/AuthContext';\r\nimport axios from 'axios';\r\nimport { User, Mail, Phone, MapPin, Calendar, Trophy, Target, Camera } from 'lucide-react';\r\nimport { useHeader } from '../../context/HeaderContext';\r\n\r\nconst UserProfile = () => {\r\n    const { user } = useAuth();\r\n    const [profile, setProfile] = useState(null);\r\n    const [loading, setLoading] = useState(true);\r\n    const [isUploading, setIsUploading] = useState(false);\r\n\r\n    const { setHeader } = useHeader();\r\n\r\n    useEffect(() => {\r\n        const fetchProfile = async () => {\r\n            if (!user?.dni) {\r\n                setLoading(false);\r\n                return;\r\n            }\r\n            try {\r\n                const res = await axios.get(`http://localhost:5000/api/auth/profile/${user.dni}`);\r\n                setProfile(res.data);\r\n            } catch (err) {\r\n                console.error('Error fetching profile:', err);\r\n            } finally {\r\n                setLoading(false);\r\n            }\r\n        };\r\n        fetchProfile();\r\n        setHeader('MI PERFIL', 'Información personal de tu cuenta.');\r\n        return () => setHeader('', '');\r\n    }, [user?.dni]);\r\n\r\n    const handlePhotoUpload = async (e) => {\r\n        const file = e.target.files[0];\r\n        if (!file) return;\r\n\r\n        const formData = new FormData();\r\n        formData.append('foto', file);\r\n\r\n        setIsUploading(true);\r\n        try {\r\n            const res = await axios.post(`http://localhost:5000/api/auth/profile/${user.dni}/foto`, formData, {\r\n                headers: { 'Content-Type': 'multipart/form-data' }\r\n            });\r\n            setProfile(prev => ({ ...prev, foto_perfil: res.data.foto_perfil }));\r\n        } catch (err) {\r\n            console.error('Error uploading photo:', err);\r\n            alert('Error al subir la foto de perfil');\r\n        } finally {\r\n            setIsUploading(false);\r\n        }\r\n    };\r\n\r\n    if (loading) {\r\n        return (\r\n            <div className=\"flex items-center justify-center h-64\">\r\n                <div className=\"w-8 h-8 border-2 border-brand-dark border-t-transparent rounded-full animate-spin\"></div>\r\n            </div>\r\n        );\r\n    }\r\n\r\n    const InfoItem = ({ icon: Icon, label, value }) => (\r\n        <div className=\"flex items-start gap-3 py-3\">\r\n            <div className=\"w-8 h-8 rounded-lg bg-gray-50 flex items-center justify-center flex-shrink-0\">\r\n                <Icon size={14} className=\"text-gray-400\" />\r\n            </div>\r\n            <div>\r\n                <p className=\"text-[10px] font-black tracking-widest text-gray-400 uppercase\">{label}</p>\r\n                <p className=\"text-sm font-bold text-brand-dark mt-0.5\">{value || '-'}</p>\r\n            </div>\r\n        </div>\r\n    );\r\n\r\n    return (\r\n        <div className=\"space-y-8 animate-in fade-in duration-500 pb-20\">\r\n            {/* Profile Info */}\r\n            <div className=\"bg-white rounded-lg border border-gray-100 shadow-sm overflow-hidden\">\r\n                <div className=\"bg-brand-dark p-6 flex flex-col sm:flex-row items-center gap-6 text-center sm:text-left\">\r\n                    <div className=\"relative group\">\r\n                        <div className={`w-24 h-24 rounded-full flex items-center justify-center text-white text-3xl font-black bg-white/10 border-4 border-brand-dark shadow-xl overflow-hidden transition-all duration-300`}>\r\n                            {profile?.foto_perfil ? (\r\n                                <img src={`http://localhost:5000${profile.foto_perfil}`} alt=\"Perfil\" className=\"w-full h-full object-cover\" />\r\n                            ) : (\r\n                                profile?.apellido?.charAt(0)?.toUpperCase() || 'U'\r\n                            )}\r\n                        </div>\r\n                    </div>\r\n                    <div className=\"flex flex-col justify-center h-24\">\r\n                        <h2 className=\"text-2xl font-black text-white uppercase tracking-wider\">\r\n                            {profile ? `${profile.apellido}, ${profile.nombre}`.toUpperCase() : 'USUARIO'}\r\n                        </h2>\r\n                        <p className=\"text-white/60 text-sm font-medium mt-1\">{profile?.email || ''}</p>\r\n                    </div>\r\n\r\n                    <div className=\"sm:ml-auto flex flex-col items-center sm:items-end gap-2\">\r\n                        <input type=\"file\" id=\"photo-upload\" accept=\"image/*\" className=\"hidden\" onChange={handlePhotoUpload} disabled={isUploading} />\r\n                        <label \r\n                            htmlFor=\"photo-upload\" \r\n                            className={`flex items-center gap-2 px-6 py-3 bg-white text-brand-dark font-black text-xs tracking-widest rounded-lg transition-all shadow-xl cursor-pointer uppercase ${isUploading ? 'opacity-50' : 'hover:bg-gray-100 hover:scale-105 active:scale-95'}`}\r\n                        >\r\n                            {isUploading ? (\r\n                                <div className=\"w-4 h-4 border-2 border-brand-dark border-t-transparent rounded-full animate-spin\"></div>\r\n                            ) : (\r\n                                <Camera size={16} />\r\n                            )}\r\n                            {isUploading ? 'SUBIENDO...' : 'SUBIR FOTO DE PERFIL'}\r\n                        </label>\r\n                        <p className=\"text-[10px] font-black text-red-500 bg-white/10 px-3 py-1 rounded-full uppercase tracking-tighter animate-pulse border border-red-500/30\">\r\n                            Subir OBLIGATORIAMENTE foto de perfil\r\n                        </p>\r\n                    </div>\r\n                </div>\r\n\r\n                <div className=\"p-6\">\r\n                    <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-1 divide-y md:divide-y-0 md:divide-x divide-gray-50\">\r\n                        <div className=\"space-y-1 pr-8\">\r\n                            <InfoItem icon={User} label=\"DNI\" value={profile?.dni} />\r\n                            <InfoItem icon={User} label=\"Sexo\" value={profile?.sexo} />\r\n                            <InfoItem icon={Calendar} label=\"Fecha de Nacimiento\" value={profile?.fecha_nacimiento ? new Date(profile.fecha_nacimiento).toLocaleDateString('es-AR') : '-'} />\r\n                            <InfoItem icon={Trophy} label=\"Nivel\" value={profile?.nivel} />\r\n                        </div>\r\n                        <div className=\"space-y-1 px-8\">\r\n                            <InfoItem icon={Mail} label=\"Email\" value={profile?.email} />\r\n                            <InfoItem icon={Phone} label=\"Teléfono\" value={profile?.telefono} />\r\n                            <InfoItem icon={Phone} label=\"Tel. Alternativo\" value={profile?.tel_alternativo} />\r\n                            <InfoItem icon={Target} label=\"Brazo Hábil\" value={profile?.brazo_habil} />\r\n                        </div>\r\n                        <div className=\"space-y-1 pl-8\">\r\n                            <InfoItem icon={MapPin} label=\"País\" value={profile?.pais} />\r\n                            <InfoItem icon={MapPin} label=\"Provincia\" value={profile?.provincia} />\r\n                            <InfoItem icon={MapPin} label=\"Localidad\" value={profile?.localidad} />\r\n                            <InfoItem icon={Target} label=\"Posición\" value={profile?.posicion} />\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    );\r\n};\r\n\r\nexport default UserProfile;\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Facundo\\Documents\\Base de datos\\web_inicial\\frontend\\src\\views\\user\\UserStats.jsx","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'setHeader'. Either include it or remove the dependency array.","line":21,"column":8,"nodeType":"ArrayExpression","endLine":21,"endColumn":10,"suggestions":[{"desc":"Update the dependencies array to be: [setHeader]","fix":{"range":[636,638],"text":"[setHeader]"}}]},{"ruleId":"no-unused-vars","severity":2,"message":"'Icon' is defined but never used.","line":32,"column":31,"nodeType":"Identifier","messageId":"unusedVar"