8 animate-in fade-in duration-500 pb-20\">","line":53,"column":18,"nodeType":null,"endLine":53,"endColumn":26}],"suppressedMessages":[],"errorCount":7,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useEffect } from 'react';\nimport { Trophy, Target, TrendingUp, Award } from 'lucide-react';\nimport { useHeader } from '../../context/HeaderContext';\n\nconst UserStats = () => {\n    // Mock match data (will be replaced with real data from backend)\n    const matchStats = {\n        partidosJugados: 42,\n        partidosGanados: 28,\n        partidosPerdidos: 14,\n        puntos: 1850,\n        rachaActual: 5,\n        mejorRacha: 8,\n    };\n\n    const { setHeader } = useHeader();\n\n    useEffect(() => {\n        setHeader('MIS PARTIDOS', 'Estadísticas de juego y partidos recientes.');\n        return () => setHeader('', '');\n    }, []);\n\n    const recentMatches = [\n        { fecha: '08/03/2025', rival: 'Martinez / Lopez', resultado: 'GANADO', puntos: '+25', score: '6-3 / 6-4' },\n        { fecha: '05/03/2025', rival: 'Garcia / Fernandez', resultado: 'GANADO', puntos: '+20', score: '7-5 / 6-2' },\n        { fecha: '01/03/2025', rival: 'Rodriguez / Sanchez', resultado: 'PERDIDO', puntos: '-15', score: '4-6 / 3-6' },\n        { fecha: '25/02/2025', rival: 'Perez / Gomez', resultado: 'GANADO', puntos: '+30', score: '6-1 / 6-3' },\n        { fecha: '20/02/2025', rival: 'Diaz / Torres', resultado: 'GANADO', puntos: '+20', score: '6-4 / 7-5' },\n        { fecha: '15/02/2025', rival: 'Alvarez / Ruiz', resultado: 'PERDIDO', puntos: '-10', score: '3-6 / 5-7' },\n    ];\n\n    const StatCard = ({ icon: Icon, label, value, color = 'text-brand-dark' }) => (\n        <div className=\"bg-white p-5 rounded-lg border border-gray-100 shadow-sm hover:shadow-md transition-shadow\">\n            <div className=\"flex items-center justify-between mb-3\">\n                <div className=\"w-10 h-10 rounded-lg bg-gray-50 flex items-center justify-center\">\n                    <Icon size={18} className=\"text-gray-400\" />\n                </div>\n            </div>\n            <p className=\"text-[10px] font-black tracking-widest text-gray-400 uppercase\">{label}</p>\n            <p className={`text-2xl font-black mt-1 ${color}`}>{value}</p>\n        </div>\n    );\n\n    return (\n        <div className=\"space-y-8 animate-in fade-in duration-500 pb-20\">\n            {/* Match Statistics */}\n            <div className=\"grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4\">\n                <StatCard icon={Target} label=\"Jugados\" value={matchStats.partidosJugados} />\n                <StatCard icon={Trophy} label=\"Ganados\" value={matchStats.partidosGanados} color=\"text-green-500\" />\n                <StatCard icon={TrendingUp} label=\"Perdidos\" value={matchStats.partidosPerdidos} color=\"text-red-400\" />\n                <StatCard icon={Award} label=\"Puntos\" value={matchStats.puntos} />\n                <StatCard icon={TrendingUp} label=\"Racha Actual\" value={matchStats.rachaActual} color=\"text-blue-500\" />\n                <StatCard icon={Award} label=\"Mejor Racha\" value={matchStats.mejorRacha} color=\"text-amber-500\" />\n            </div>\n\n            {/* Recent Matches Table */}\n            <div className=\"bg-white rounded-lg border border-gray-100 shadow-sm overflow-hidden\">\n                <div className=\"p-5 border-b border-gray-50\">\n                    <h3 className=\"text-sm font-black text-brand-dark uppercase tracking-wider\">Últimos Partidos</h3>\n                </div>\n                <div className=\"overflow-x-auto\">\n                    <table className=\"w-full\">\n                        <thead>\n                            <tr className=\"border-b border-gray-50\">\n                                <th className=\"text-left px-6 py-3 text-[10px] font-black tracking-widest text-gray-400 uppercase\">Fecha</th>\n                                <th className=\"text-left px-6 py-3 text-[10px] font-black tracking-widest text-gray-400 uppercase\">Rival</th>\n                                <th className=\"text-left px-6 py-3 text-[10px] font-black tracking-widest text-gray-400 uppercase\">Score</th>\n                                <th className=\"text-left px-6 py-3 text-[10px] font-black tracking-widest text-gray-400 uppercase\">Resultado</th>\n                                <th className=\"text-right px-6 py-3 text-[10px] font-black tracking-widest text-gray-400 uppercase\">Puntos</th>\n                            </tr>\n                        </thead>\n                        <tbody>\n                            {recentMatches.map((match, index) => (\n                                <tr key={index} className=\"border-b border-gray-50/50 hover:bg-gray-50/30 transition-colors\">\n                                    <td className=\"px-6 py-4 text-sm font-medium text-brand-gray\">{match.fecha}</td>\n                                    <td className=\"px-6 py-4 text-sm font-bold text-brand-dark uppercase\">{match.rival}</td>\n                                    <td className=\"px-6 py-4 text-sm font-medium text-brand-gray\">{match.score}</td>\n                                    <td className=\"px-6 py-4\">\n                                        <span className={`px-2.5 py-1 text-[10px] font-black tracking-wider rounded-md ${match.resultado === 'GANADO'\n                                                ? 'bg-green-50 text-green-600'\n                                                : 'bg-red-50 text-red-500'\n                                            }`}>\n                                            {match.resultado}\n                                        </span>\n                                    </td>\n                                    <td className={`px-6 py-4 text-right text-sm font-black ${match.puntos.startsWith('+') ? 'text-green-500' : 'text-red-400'\n                                        }`}>\n                                        {match.puntos}\n                                    </td>\n                                </tr>\n                            ))}\n                        </tbody>\n                    </table>\n                </div>\n                <div className=\"p-4 bg-gray-50/30 border-t border-gray-50\">\n                    <span className=\"text-[10px] font-black text-gray-400 uppercase tracking-widest\">\n                        Mostrando {recentMatches.length} partidos recientes\n                    </span>\n                </div>\n            </div>\n        </div>\n    );\n};\n\nexport default UserStats;\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Facundo\\Documents\\Base de datos\\web_inicial\\frontend\\tailwind.config.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Facundo\\Documents\\Base de datos\\web_inicial\\frontend\\vite.config.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]}]
